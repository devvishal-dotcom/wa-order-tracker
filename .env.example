# ─── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ────────────────────────────────────────────────
DB_PATH=orders.db

# ─── WhatsApp Business Cloud API ─────────────────────────────
# Get these from: https://developers.facebook.com/apps → WhatsApp → API Setup

WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_ACCESS_TOKEN=your_permanent_access_token_here

# Template settings (create in Meta Business Manager)
WA_TEMPLATE_NAME=order_tracking
WA_TEMPLATE_LANG=en_US

# ─── Webhook ─────────────────────────────────────────────────
# This token you INVENT — then paste it into Meta's webhook config
WA_WEBHOOK_VERIFY_TOKEN=wa_tracker_secret_change_me
